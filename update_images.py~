import os
import pandas as pd

# ─── CONFIGURATION ────────────────────────────────────────────────────────────
CSV_FILE    = "combined_database_updated.csv"
DIRECTORIES = ["herm_1", "herm_2", "herm_3", "herm_4"]
IMG_COL     = "img1"
ID_COL      = "id"
# ──────────────────────────────────────────────────────────────────────────────


def build_image_index(directories):
    """
    Scan all directories and return a dict: { file_stem → '/herm_X/stem.jpg' }
    File stem = filename without extension, used to match against id column.
    """
    index = {}
    for folder in directories:
        if not os.path.isdir(folder):
            print(f"  [WARN] Directory not found, skipping: {folder}")
            continue
        for fname in os.listdir(folder):
            stem, ext = os.path.splitext(fname)
            if ext.lower() in (".jpg", ".jpeg", ".png", ".tif", ".tiff"):
                path = f"/{folder}/{stem}.jpg"
                if stem in index:
                    print(f"  [WARN] Duplicate id '{stem}' found in {folder} "
                          f"(already mapped to {index[stem]})")
                else:
                    index[stem] = path
    return index


def fill_img1(csv_file, image_index, id_col, img_col):
    """
    Load CSV, fill empty img1 cells where id matches a file in image_index.
    """
    df = pd.read_csv(csv_file, dtype=str)

    # Normalise column names (strip accidental whitespace)
    df.columns = df.columns.str.strip()

    if id_col not in df.columns:
        raise ValueError(f"Column '{id_col}' not found in CSV. "
                         f"Available columns: {list(df.columns)}")

    # Create img1 column if it doesn't exist at all
    if img_col not in df.columns:
        df[img_col] = ""

    # Identify rows where img1 is empty/NaN
    empty_mask = df[img_col].isna() | (df[img_col].str.strip() == "")

    matched   = 0
    unmatched = []

    for idx in df[empty_mask].index:
        row_id = str(df.at[idx, id_col]).strip()

        if row_id in image_index:
            df.at[idx, img_col] = image_index[row_id]
            matched += 1
        else:
            unmatched.append(row_id)

    # Save back to the same CSV
    df.to_csv(csv_file, index=False)

    return matched, unmatched


# ─── MAIN ─────────────────────────────────────────────────────────────────────
if __name__ == "__main__":
    print("Step 1 — Scanning image directories...")
    image_index = build_image_index(DIRECTORIES)
    print(f"  Found {len(image_index):,} unique image files across "
          f"{len(DIRECTORIES)} directories.\n")

    print("Step 2 — Loading CSV and filling empty img1 entries...")
    matched, unmatched = fill_img1(CSV_FILE, image_index, ID_COL, IMG_COL)

    print(f"\n{'─' * 50}")
    print(f"  Matched & filled : {matched:,} rows")
    print(f"  Still empty      : {len(unmatched):,} rows (no image file found)")
    print(f"{'─' * 50}")

    if unmatched:
        print(f"\n  IDs with no matching image file:")
        for uid in unmatched[:20]:          # show first 20
            print(f"    - {uid}")
        if len(unmatched) > 20:
            print(f"    ... and {len(unmatched) - 20} more")

    print(f"\n  Saved → {CSV_FILE}")
